{
  "name": "memctx",
  "version": "1.0.11",
  "description": "Autonomous session memory for Claude Code - automatically captures, analyzes, and summarizes your development sessions",
  "author": "Fahad Aziz Qureshi <info@memctx.dev> (https://memctx.dev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bbhunterpk-ux/memctx.git"
  },
  "bugs": {
    "url": "https://github.com/bbhunterpk-ux/memctx/issues"
  },
  "homepage": "https://memctx.dev",
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "memory",
    "context",
    "session-tracking",
    "anthropic",
    "development-tools",
    "productivity",
    "memctx"
  ],
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "memctx": "./dist/bin/claudectx.js"
  },
  "files": [
    "dist/",
    "dashboard/dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "dev": "NODE_NO_WARNINGS=1 tsx watch src/index.ts",
    "dev:dashboard": "cd dashboard && vite --port $PORT",
    "build": "pnpm run build:worker && pnpm run build:dashboard",
    "build:worker": "tsc -p tsconfig.worker.json && cp -r installer/hooks-settings.json dist/installer/ && cp -r src/hooks/*.js dist/src/hooks/ 2>/dev/null || true && cp -r src/db/migrations dist/src/db/",
    "build:dashboard": "cd dashboard && pnpm install && pnpm vite build",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "express": "^5.2.1",
    "p-queue": "^9.1.2",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.12.0",
    "@types/ws": "^8.5.10",
    "tsx": "catalog:",
    "typescript": "~6.0.2"
  }
}
