{
  "name": "@workspace/claudectx",
  "version": "1.0.0",
  "description": "Autonomous session memory for Claude Code",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "claudectx": "./dist/bin/claudectx.js"
  },
  "scripts": {
    "dev": "NODE_NO_WARNINGS=1 tsx watch src/index.ts",
    "dev:dashboard": "cd dashboard && vite --port $PORT",
    "build": "pnpm run build:worker && pnpm run build:dashboard",
    "build:worker": "tsc -p tsconfig.worker.json",
    "build:dashboard": "cd dashboard && pnpm vite build",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.26.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^3.6.0",
    "express": "^4.19.2",
    "p-queue": "^8.0.1",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.0",
    "@types/ws": "^8.5.10",
    "tsx": "catalog:",
    "typescript": "~5.9.2"
  }
}
